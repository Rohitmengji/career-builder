# Dependencies
node_modules/

# Next.js build output
.next/
out/

# Turbo cache
.turbo/

# Environment files (contain secrets)
.env
.env.local
.env.*.local

# Database
*.db
*.db-journal

# Prisma generated client (regenerated on install)
node_modules/.prisma/

# Local data (uploads, file-based stores). The dev servers and the local
# storage driver write resumes/media here; never commit uploaded files.
data/
apps/admin/data/
apps/web/data/

# Editor / backup scratch files
*.bak

# Playwright / UI-audit generated output
test-results/
playwright-report/
ui-audit/reports/
ui-audit/screenshots/

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/settings.json
*.swp
*.swo

# Vercel
.vercel/

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# TypeScript cache
*.tsbuildinfo
.vercel
.env*.local
