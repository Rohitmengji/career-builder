# ─── Career Site Builder — Admin App ────────────────────────────
# Copy this file to .env.local and fill in the values.
# On Vercel: set these in Project → Settings → Environment Variables.

# ─── Database (Required) ─────────────────────────────────────────
# Local SQLite:
DATABASE_URL="file:./dev.db"
# Turso (recommended for Vercel — free tier: 8GB):
# DATABASE_URL="libsql://your-db.turso.io?authToken=your-token"
# Neon PostgreSQL (alternative — free tier: 0.5GB):
# DATABASE_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require"

# ─── Tenant (Required) ───────────────────────────────────────────
TENANT_ID=default

# ─── URLs ─────────────────────────────────────────────────────────
# This admin app's public URL (REQUIRED in production)
NEXT_PUBLIC_APP_URL=http://localhost:3001
# The web (public) app's URL — used for preview links and CORS
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Session Security ────────────────────────────────────────────
# REQUIRED in production. Generate with: openssl rand -base64 32
# SESSION_SECRET=

# ─── File Storage (uploads / media) ──────────────────────────────
# Local filesystem is the default (fine for dev). On Vercel/serverless the
# local disk is EPHEMERAL — set a durable driver in production.
# STORAGE_DRIVER=local            # local | blob | s3   (default: local)
# Vercel Blob (npm i @vercel/blob):
# STORAGE_DRIVER=blob
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
# S3 / R2 / MinIO (npm i @aws-sdk/client-s3):
# STORAGE_DRIVER=s3
# S3_BUCKET=my-bucket
# S3_PUBLIC_BASE_URL=https://cdn.example.com
# S3_REGION=auto
# S3_ENDPOINT=                    # for R2/MinIO; omit for AWS S3

# ─── Durable KV (rate limits / lockouts / webhook idempotency) ───
# Default is in-process memory (per-instance, lost on cold start). On serverless
# set a shared store so these survive across instances:
# KV_DRIVER=redis                 # memory | redis   (default: memory)
# UPSTASH_REDIS_REST_URL=https://...upstash.io   (npm i @upstash/redis)
# UPSTASH_REDIS_REST_TOKEN=...
# Number of trusted reverse proxies in front of the app (for client-IP /
# rate-limit keys). 1 is correct for a single Vercel/Cloudflare hop.
# TRUSTED_PROXY_COUNT=1

# ─── AI Features (Optional) ──────────────────────────────────────
# Get from https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-proj-...
# AI_MODEL=gpt-5.4-mini
# OPENAI_BASE_URL=  # Only for Azure OpenAI or proxies

# ─── Stripe Billing (Optional) ───────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys
# Use TEST keys for development and preview environments!
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRO_PRICE_ID=price_...
# STRIPE_ENT_PRICE_ID=price_...

# ─── Vercel Auto-Set (DO NOT SET MANUALLY) ───────────────────────
# These are automatically set by Vercel:
# VERCEL=1
# VERCEL_URL=your-project.vercel.app
# VERCEL_ENV=production|preview|development
# VERCEL_GIT_COMMIT_SHA=abc1234...
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRO_PRICE_ID=price_...
# STRIPE_ENT_PRICE_ID=price_...
