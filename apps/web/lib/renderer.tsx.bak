  return (
    <Section variant="light">
      <Container className="text-center max-w-2xl">
        <h2 className="text-3xl md:text-4xl font-semibold tracking-tight mb-4" style={{ color: tokens.colors.text, fontFamily: tokens.typography.headingFontFamilyCss }}>{p.title}</h2>
        {p.subtitle && <p className="mb-8 leading-relaxed" style={{ color: tokens.colors.textMuted }}>{p.subtitle}</p>}
        <Btn href={p.buttonLink} color={p.color}>{p.buttonText}</Btn>
      </Container>
    </Section>
