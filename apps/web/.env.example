# ─── Career Site Builder — Web App ──────────────────────────────
# Copy this file to .env.local and fill in the values.
# On Vercel: set these in Project → Settings → Environment Variables.

# ─── Database (Required) ─────────────────────────────────────────
# Must point to the SAME database as the admin app.
DATABASE_URL="file:../../apps/admin/dev.db"
# Turso (recommended for Vercel — free tier: 8GB):
# DATABASE_URL="libsql://your-db.turso.io?authToken=your-token"
# Neon PostgreSQL (alternative):
# DATABASE_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require"

# ─── Tenant (Required) ───────────────────────────────────────────
TENANT_ID=default

# ─── URLs ─────────────────────────────────────────────────────────
# This web app's public URL (REQUIRED in production)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Admin app URL — used for server-side API calls (page data, theme, etc.)
ADMIN_API_URL=http://localhost:3001
# Or for client-side components (marketing CTAs, etc.):
NEXT_PUBLIC_ADMIN_API_URL=http://localhost:3001
# Alternatively (same effect):
# NEXT_PUBLIC_APP_URL=http://localhost:3001

# ─── Vercel Auto-Set (DO NOT SET MANUALLY) ───────────────────────
# VERCEL=1
# VERCEL_URL=your-project.vercel.app
# VERCEL_ENV=production|preview|development
# VERCEL_GIT_COMMIT_SHA=abc1234...
