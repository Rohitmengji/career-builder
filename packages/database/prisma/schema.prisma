// ============================================================
// Career Builder — Prisma Schema
// ============================================================
// SQLite for development. Switch to PostgreSQL in production by
// changing the datasource provider and DATABASE_URL.
//
// All entities carry a tenantId for multi-tenant isolation.
// ============================================================

generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// --- TENANT ---

model Tenant {
  id        String   @id @default(cuid())
  name      String
  domain    String?  @unique
  theme     String   @default("{}") // JSON blob
  branding  String   @default("{}") // JSON blob
  settings  String   @default("{}") // JSON blob
  plan      String   @default("free") // free | pro | enterprise
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  users        User[]
  jobs         Job[]
  pages        Page[]
  applications Application[]
  auditLogs    AuditLog[]
  analytics    AnalyticsEvent[]
  webhooks     Webhook[]
  candidates   Candidate[]
  domains      Domain[]
  pipelineStages PipelineStage[]
  applicationTags     ApplicationTag[]
  applicationTagLinks ApplicationTagOnApplication[]
  savedViews          SavedView[]
  talentPools        TalentPool[]
  talentPoolMembers  TalentPoolMember[]
}

// --- DOMAIN (custom domains per tenant) ---

model Domain {
  id          String    @id @default(cuid())
  hostname    String    @unique // exact host, e.g. careers.acme.com (lowercased)
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // pending | verified | active | failed  (string, not enum — sqlite/turso)
  status      String    @default("pending")
  verifyToken String // random token placed in the DNS TXT record
  isPrimary   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  verifiedAt  DateTime?

  @@index([tenantId])
  @@index([status])
}

// --- USER ---

model User {
  id           String   @id @default(cuid())
  email        String
  name         String
  passwordHash String
  role         String   @default("viewer")
  department   String?
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?
  passwordChangedAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Subscription & Billing
  plan                 String   @default("free")
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?  @unique
  stripePriceId        String?
  subscriptionStatus   String   @default("none")
  aiCredits            Int      @default(0)
  aiCreditsResetAt     DateTime?
  billingCycleStart    DateTime?

  // Job AI credits (weekly cap, separate from page AI credits)
  jobAiCredits         Int      @default(0)
  jobAiCreditsResetAt  DateTime?

  // Daily AI usage tracking (server-enforced daily cap)
  aiDailyUsed          Int      @default(0)
  aiDailyResetAt       DateTime?

  // Tenant isolation
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Relations
  auditLogs AuditLog[]
  comments  ApplicationComment[]
  interviews Interview[]
  scorecards Scorecard[]
  offersCreated  Offer[] @relation("OfferCreatedBy")
  offersApproved Offer[] @relation("OfferApprover")
  adverseActions AdverseAction[]
  savedViews     SavedView[]

  @@unique([email, tenantId])
  @@index([tenantId])
  @@index([stripeCustomerId])
}

// --- JOB ---

model Job {
  id              String   @id @default(cuid())
  title           String
  slug            String
  department      String
  location        String
  description     String
  employmentType  String   @default("full-time")
  experienceLevel String   @default("mid")
  salaryMin       Int?
  salaryMax       Int?
  salaryCurrency  String   @default("USD")
  salaryPeriod    String   @default("yearly")
  requirements    String   @default("[]") // JSON array
  niceToHave      String   @default("[]") // JSON array
  benefits        String   @default("[]") // JSON array
  tags            String   @default("[]") // JSON array
  screeningQuestions String @default("[]") // JSON array of { q, requiredAnswer }
  scorecardCriteria  String @default("[]") // JSON array of criterion label strings
  isRemote        Boolean  @default(false)
  isPublished     Boolean  @default(false)
  sortOrder       Int      @default(0)
  postedAt        DateTime @default(now())
  closesAt        DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // ATS integration fields
  externalId     String?
  externalSource String?
  externalUrl    String?

  // Tenant isolation
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Relations
  applications Application[]
  pipelineStages PipelineStage[]

  @@unique([slug, tenantId])
  @@index([tenantId])
  @@index([tenantId, isPublished])
  @@index([department])
  @@index([location])
}

// --- APPLICATION ---

model Application {
  id          String   @id @default(cuid())
  firstName   String
  lastName    String
  email       String
  phone       String?
  resumeUrl   String?
  resumePath  String?
  resumeText  String?  // Extracted plain text from the uploaded resume (server-side, best-effort)
  screeningAnswers String? // JSON: { answers: {idx: yes|no}, passed, failed[] } — non-identifying
  coverLetter String?
  linkedinUrl String?
  status      String   @default("applied")
  rating      Int?
  notes       String?
  source      String?
  // Data-rights (ADR-0011): set when this application's PII has been anonymized
  // (GDPR §17 erasure / retention purge). legalHold exempts it from both.
  anonymizedAt   DateTime?
  legalHold      Boolean  @default(false)
  legalHoldReason String?
  // Interview feedback (ADR-0012): when set, an anonymized scorecard summary is
  // released to the candidate (deliberate recruiter action, post-decision).
  feedbackReleasedAt DateTime?
  submittedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // ATS integration
  externalId String?

  // Relations
  jobId    String
  job      Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // Customizable pipeline stage (ADR-0015). `status` (above) is RETAINED as a
  // derived back-compat cache; stageId is the FK once custom stages are enabled.
  stageId  String?
  stage    PipelineStage? @relation(fields: [stageId], references: [id], onDelete: SetNull)
  comments ApplicationComment[]
  events   ApplicationEvent[]
  interviews Interview[]
  scorecards Scorecard[]
  offers   Offer[]
  adverseAction AdverseAction?
  tags     ApplicationTagOnApplication[]

  @@index([jobId])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, stageId])
  @@index([email, tenantId])
  // One application per candidate per job (email is stored lowercased). The
  // ATOMIC backstop for duplicate prevention: a concurrent double-submit that
  // races past the app-level check hits this constraint (Prisma P2002).
  @@unique([tenantId, jobId, email])
}

// --- APPLICATION COMMENT (internal hiring-team discussion) ---

model ApplicationComment {
  id            String      @id @default(cuid())
  tenantId      String
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  authorId      String
  author        User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body          String
  mentions      String      @default("[]") // JSON array of userIds (sqlite has no scalar lists)
  createdAt     DateTime    @default(now())

  @@index([applicationId])
  @@index([tenantId])
}

// --- APPLICATION EVENT (workflow timeline — see ADR-0005) ---

model ApplicationEvent {
  id            String      @id @default(cuid())
  tenantId      String
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  type          String      // status_change | interview_scheduled | offer_extended | ...
  fromStatus    String?
  toStatus      String?
  actorId       String?     // User or Candidate id; null for system
  actorType     String      @default("system") // recruiter | candidate | system
  visibility    String      @default("internal") // candidate | internal
  metadata      String?     // JSON — NEVER candidate PII
  createdAt     DateTime    @default(now())

  @@index([tenantId, applicationId])
  @@index([tenantId, type])
}

// --- INTERVIEW (scheduling — see ADR-0006) ---

model Interview {
  id            String      @id @default(cuid())
  tenantId      String
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  jobId         String?
  round         Int         @default(1)
  type          String      @default("video")     // phone | video | onsite
  status        String      @default("scheduled") // scheduled | confirmed | cancelled | completed | no_show
  interviewerId String?
  interviewer   User?       @relation(fields: [interviewerId], references: [id], onDelete: SetNull)
  scheduledAt   DateTime                          // stored UTC
  durationMins  Int         @default(45)
  timezone      String      @default("UTC")       // IANA, for display
  location      String?
  meetingUrl    String?
  notes         String?                           // internal interviewer notes
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([tenantId, applicationId])
  @@index([tenantId, status])
  @@index([interviewerId])
}

// --- SCORECARD (ADR-0007) ---

model Scorecard {
  id             String            @id @default(cuid())
  tenantId       String
  applicationId  String
  application    Application       @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  interviewId    String?                                  // optional link to a specific interview
  interviewerId  String                                   // the User who submitted it
  interviewer    User              @relation(fields: [interviewerId], references: [id], onDelete: Cascade)
  recommendation String                                   // strong_yes | yes | no | strong_no
  overallNotes   String?
  ratings        ScorecardRating[]
  submittedAt    DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  // One scorecard per interviewer per application — re-submitting replaces theirs.
  @@unique([tenantId, applicationId, interviewerId])
  @@index([tenantId, applicationId])
}

model ScorecardRating {
  id          String    @id @default(cuid())
  scorecardId String
  scorecard   Scorecard @relation(fields: [scorecardId], references: [id], onDelete: Cascade)
  criterion   String                                      // denormalized label (survives rubric edits)
  score       Int                                         // 1-5
  comment     String?

  @@index([scorecardId])
}

// --- OFFER (ADR-0008) ---

model Offer {
  id             String      @id @default(cuid())
  tenantId       String
  applicationId  String
  application    Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  jobId          String?

  status         String      @default("draft")
  // draft | pending_approval | approved | sent | accepted | declined | expired | rescinded

  // Compensation (mirrors Job's money convention)
  salaryAmount   Int?
  salaryCurrency String      @default("USD")
  salaryPeriod   String      @default("yearly") // yearly | monthly | hourly

  startDate      DateTime?                       // proposed start (stored UTC)
  expiresAt      DateTime?                       // offer deadline (UTC); null = no expiry
  terms          String?                         // candidate-visible additional terms
  notes          String?                         // internal recruiter notes — NEVER candidate-visible

  // People
  createdById    String
  createdBy      User        @relation("OfferCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  approverId     String?
  approver       User?       @relation("OfferApprover", fields: [approverId], references: [id], onDelete: SetNull)

  // Lifecycle stamps
  approvedAt     DateTime?
  sentAt         DateTime?
  respondedAt    DateTime?                       // accepted OR declined time
  decisionNote   String?                         // candidate-authored note on accept/decline

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([tenantId, applicationId])
  @@index([tenantId, status])
  @@index([approverId])
}

// --- NOTIFICATION (ADR-0009, Phase 4) ---

model Notification {
  id            String    @id @default(cuid())
  tenantId      String
  recipientType String    // "user" (recruiter) | "candidate"
  recipientId   String    // User id (user) OR lowercased application email (candidate, ADR-0001)
  type          String    // event type / notification kind
  title         String
  body          String?
  link          String?
  applicationId String?    // optional deep-link context
  readAt        DateTime?
  createdAt     DateTime  @default(now())

  @@index([tenantId, recipientType, recipientId, readAt])
  @@index([tenantId, recipientType, recipientId, createdAt])
}

// --- EEO SELF-ID (ADR-0013) ---
//
// Voluntary candidate demographics for AGGREGATE EEO reporting only. ARCHITECTURALLY
// ISOLATED from the hiring path: there is deliberately NO Prisma relation to/from
// Application (so no recruiter query can `include` it), and eeoRepo exposes no
// individual read — only record() + a suppressed aggregate(). Keyed by applicationId
// but it is a plain column, not a foreign key.
model EeoSelfId {
  id            String   @id @default(cuid())
  tenantId      String
  applicationId String   @unique
  gender        String?  // closed vocab incl. "decline_to_state"
  race          String?
  ethnicity     String?
  veteranStatus String?
  disability    String?
  createdAt     DateTime @default(now())

  @@index([tenantId])
}

// --- CONSENT (ADR-0011) ---

model Consent {
  id            String   @id @default(cuid())
  tenantId      String
  subjectEmail  String   // lowercased — keyed by email+tenant (ADR-0001, no candidateId FK)
  type          String   // privacy_policy | data_processing | marketing
  policyVersion String   // the exact version consented to, e.g. "2026-06-01"
  granted       Boolean  // append-only: withdrawal is a NEW granted=false row
  source        String   // apply | register | profile_settings
  ipAddress     String?
  createdAt     DateTime @default(now())

  @@index([tenantId, subjectEmail, type, createdAt])
}

// --- ADVERSE ACTION (ADR-0010) ---

model AdverseAction {
  id            String      @id @default(cuid())
  tenantId      String
  applicationId String      @unique
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  kind          String      @default("rejection") // rejection | offer_declined | offer_rescinded
  category      String      // CLOSED vocab (see shared/adverse-action.ts)
  freeText      String?     // INTERNAL rationale — NEVER auto-shown to the candidate
  stage         String?     // application status/stage at decision (funnel analytics)
  sharedWithCandidate Boolean @default(false)
  candidateMessage    String? // curated, candidate-safe copy (distinct from freeText)
  decidedById   String?
  decidedBy     User?       @relation(fields: [decidedById], references: [id], onDelete: SetNull)
  decidedAt     DateTime    @default(now())
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([tenantId, category])
  @@index([tenantId, kind])
}

// --- PIPELINE STAGE (ADR-0015) ---

model PipelineStage {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  jobId     String?  // null = tenant-default pipeline; set = per-job override
  job       Job?     @relation(fields: [jobId], references: [id], onDelete: Cascade)

  key        String  // stable slug (== legacy status string for default stages)
  label      String  // display name
  kind       String  // applied | in_process | offer | hired | rejected | custom
  order      Int     @default(0)
  color      String?
  isActive   Boolean @default(true)  // soft-retire (history still references it)
  isTerminal Boolean @default(false) // hired/rejected — no auto-advance out
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  applications Application[]

  @@unique([tenantId, jobId, key])
  @@index([tenantId])
  @@index([tenantId, jobId, order])
}

// --- PAGE ---

model Page {
  id              String   @id @default(cuid())
  slug            String
  title           String   @default("")
  blocks          String   @default("[]") // JSON — draft (editor working copy)
  publishedBlocks String   @default("[]") // JSON — live (what the web app serves)
  isPublished     Boolean  @default(true)
  publishedAt     DateTime?              // Last publish timestamp
  sortOrder       Int      @default(0)
  version         Int      @default(1)   // Incremented on every save — optimistic locking
  publishedVersion Int     @default(0)   // Version number that was last published
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Tenant isolation
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Relations
  versions PageVersion[]

  @@unique([slug, tenantId])
  @@index([tenantId])
}

// --- PAGE VERSION (history / rollback) ---

model PageVersion {
  id        String   @id @default(cuid())
  version   Int // Matches Page.version at the time of snapshot
  blocks    String   @default("[]") // Snapshot of blocks JSON
  title     String   @default("")
  savedBy   String?  // userId who saved this version
  savedByEmail String? // Email for display without user lookup
  createdAt DateTime @default(now())

  // Parent page
  pageId   String
  page     Page   @relation(fields: [pageId], references: [id], onDelete: Cascade)

  // Tenant isolation (denormalized for query efficiency)
  tenantId String

  @@unique([pageId, version])
  @@index([pageId])
  @@index([tenantId])
  @@index([createdAt])
}

// --- AUDIT LOG ---

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String?
  entityId  String?
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())

  // Relations
  userId   String?
  user     User?  @relation(fields: [userId], references: [id], onDelete: SetNull)
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, action])
  @@index([userId])
}

// --- ANALYTICS EVENT ---

model AnalyticsEvent {
  id          String   @id @default(cuid())
  type        String
  jobId       String?
  pageSlug    String?
  metadata    String?
  sessionId   String?
  referrer    String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  createdAt   DateTime @default(now())

  // Tenant isolation
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, type])
  @@index([tenantId, jobId])
  @@index([tenantId, createdAt])
  @@index([createdAt])
}

// --- WEBHOOK ---

model Webhook {
  id        String   @id @default(cuid())
  url       String
  events    String   // JSON array of event types
  secret    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Tenant isolation
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// --- CANDIDATE ---
// Candidate (job-seeker) accounts for the public career site. Separate from
// User (which is for tenant staff with RBAC). Tenant-scoped.

model Candidate {
  id           String   @id @default(cuid())
  email        String
  passwordHash String
  firstName    String
  lastName     String
  phone        String?
  location     String?
  linkedinUrl  String?
  resumeUrl    String?
  headline     String?
  bio          String?

  // Password reset (token is stored hashed; never the raw token)
  resetTokenHash   String?
  resetTokenExpiry DateTime?

  isActive  Boolean  @default(true)
  lastLoginAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Tenant isolation
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([email, tenantId])
  @@index([tenantId])
  @@index([resetTokenHash])
}

// --- APP CONFIG ---
// Key-value store for dynamic application configuration.
// Replaces hardcoded constants — configurable via Admin UI.

model AppConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// --- APPLICATION TAGS (ADR-0016, B2b) ---
// Per-tenant tag library (ApplicationTag) + a many-to-many join to applications
// (ApplicationTagOnApplication). Tags let recruiters annotate/segment candidates
// (e.g. "referral", "strong-culture-fit") and filter the pipeline by them.
// tenantId is carried on BOTH sides AND on the join row: tag-link rows are the
// cross-tenant-sensitive surface, so the join is unambiguously tenant-owned
// (defense-in-depth on top of the application's + tag's own tenantId).

model ApplicationTag {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  label     String
  color     String?  // a key from shared/tags.TAG_COLORS (closed palette — never raw CSS)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  applications ApplicationTagOnApplication[]

  @@unique([tenantId, label]) // one tag per label per tenant (rename-safe library)
  @@index([tenantId])
}

model ApplicationTagOnApplication {
  id            String         @id @default(cuid())
  tenantId      String
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  applicationId String
  application   Application    @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  tagId         String
  tag           ApplicationTag @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdById   String?        // who tagged it (no FK — survives user deletion)
  createdAt     DateTime       @default(now())

  @@unique([applicationId, tagId]) // a tag is on an application at most once
  @@index([tenantId, tagId])
  @@index([tenantId, applicationId])
}

// --- SAVED VIEWS (ADR-0016, B2b) ---
// Named filter presets on the applications list, PRIVATE to the user who saved
// them (scoped by tenantId + userId). `filters` is a JSON object restricted to a
// whitelisted key set (shared/saved-view.SAVED_VIEW_FILTER_KEYS) so it can never
// smuggle arbitrary query shape into the list endpoint.

model SavedView {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  filters   String   // JSON: { status?, jobId?, department?, q?, tags?: string[] }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, userId])
}

// --- TALENT POOL / CRM (ADR-0018, B3) ---
// Per-tenant named buckets of candidates a recruiter wants to keep warm for future
// roles. Membership is keyed by candidate EMAIL (the person, not a single
// application — ADR-0001 candidate ownership by email+tenant, no candidateId FK).
// candidateName is a denormalized snapshot for display (redacted under blind hiring
// at the API; deleted on GDPR erasure along with the email — ADR-0011).

model TalentPool {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String?
  createdById String?  // who created it (no FK — survives user deletion)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members TalentPoolMember[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model TalentPoolMember {
  id             String   @id @default(cuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  poolId         String
  pool           TalentPool @relation(fields: [poolId], references: [id], onDelete: Cascade)
  candidateEmail String   // lowercased — the CRM identity (PII; erased on GDPR §17)
  candidateName  String?  // denormalized snapshot for display (PII; erased on §17)
  note           String?
  addedById      String?  // who added them (no FK)
  createdAt      DateTime @default(now())

  @@unique([poolId, candidateEmail]) // a candidate is in a pool at most once
  @@index([tenantId, poolId])
  @@index([tenantId, candidateEmail]) // fast erasure delete-by-email (ADR-0011)
}
